# ============================================================
# LLM API 配置 (多厂商支持)
# ============================================================

# 方式 1: 使用 Anthropic Claude (推荐)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# MODEL=claude-opus-4-6

# 方式 2: 使用其他厂商（OpenAI 兼容接口）
# 配置以下三个变量即可自动识别厂商
LLM_API_KEY="sk-ceea97127c7e4910b11615b6da166747"
LLM_MODEL_ID="qwen-plus"
LLM_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"

# 其他厂商配置示例：
#
# OpenAI GPT:
# LLM_API_KEY=sk-xxxxx
# LLM_MODEL_ID=gpt-4
# LLM_BASE_URL=https://api.openai.com/v1
#
# DeepSeek:
# LLM_API_KEY=sk-xxxxx
# LLM_MODEL_ID=deepseek-chat
# LLM_BASE_URL=https://api.deepseek.com/v1
#
# 阿里云通义千问:
# LLM_API_KEY=sk-xxxxx
# LLM_MODEL_ID=qwen-plus
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ============================================================
# GitHub 集成 (PR 自动化审查)
# ============================================================
GITHUB_TOKEN=your_github_token_here
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# ============================================================
# 模型配置
# ============================================================
MODEL=claude-opus-4-6
MAX_TOKENS=16000

# ============================================================
# Agent 配置
# ============================================================
ENABLE_PARALLEL_AGENTS=true
AGENT_TIMEOUT=300

# ============================================================
# 增量审查配置
# ============================================================
# 触发增量审查的最少新 commit 数（0 = 有新 commit 即触发）
INCREMENTAL_MIN_COMMITS=0
# 距上次审查的最少分钟数（0 = 不限制）
INCREMENTAL_MIN_MINUTES=0
# 是否要求所有阈值同时满足（true=AND, false=OR）
INCREMENTAL_REQUIRE_ALL_THRESHOLDS=false
# 是否在 commit 摘要中跳过 merge commit
INCREMENTAL_SKIP_MERGE_COMMITS=true

# ============================================================
# Diff Pipeline 配置
# ============================================================
# 每个 chunk 的最大 token 数
# DIFF_MAX_TOKENS_PER_CHUNK=6000
# chunk 数量上限（留空时根据模型上下文窗口动态计算）
# DIFF_MAX_CHUNKS=24
# 模型上下文窗口大小（仅当模型不在内置映射中时需要手动设置）
# MODEL_CONTEXT_WINDOW=128000

# ============================================================
# Redis 任务队列配置
# ============================================================
# Redis 连接 URL（不配置时 webhook 回退到内存模式）
# REDIS_URL=redis://localhost:6379/0
# 最大并发审查数（Worker 级别）
MAX_CONCURRENT_REVIEWS=3
# 最大并发 LLM API 调用数（全局，防止 rate limit）
MAX_CONCURRENT_LLM_CALLS=10
# 任务失败最大重试次数
TASK_MAX_RETRIES=3

# ============================================================
# Tracing 配置
# ============================================================
# 是否启用 trace 采集
TRACING_ENABLED=true
# trace JSON 文件输出目录
TRACE_OUTPUT_DIR=traces
